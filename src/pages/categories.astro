---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Categorías y Atributos" activeNav="categories">
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    
    <!-- Columna Categorías -->
    <div class="space-y-5">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-white">Categorías</h2>
          <p class="text-sm text-slate-500 mt-0.5">Organiza el catálogo de productos</p>
        </div>
        <button id="btn-new-category" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
          Nueva Categoría
        </button>
      </div>
      <div class="glass-card rounded-xl overflow-hidden">
        <table class="cms-table">
          <thead><tr>
            <th>#</th><th>Nombre</th><th>Orden</th><th class="text-right">Acciones</th>
          </tr></thead>
          <tbody id="categories-body">
            <tr><td colspan="4" class="text-center py-10 text-slate-500">Cargando categorías...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Columna Atributos -->
    <div class="space-y-5">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-white">Atributos</h2>
          <p class="text-sm text-slate-500 mt-0.5">Tallas, Colores, Materiales…</p>
        </div>
        <button id="btn-new-attr" class="btn-primary">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
          Nuevo Atributo
        </button>
      </div>
      <div class="glass-card rounded-xl overflow-hidden">
        <table class="cms-table">
          <thead><tr>
            <th>#</th><th>Nombre</th><th>Estado</th><th class="text-right">Acciones</th>
          </tr></thead>
          <tbody id="attributes-body">
            <tr><td colspan="4" class="text-center py-10 text-slate-500">Cargando atributos...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Dialog -->
  <dialog id="category-dialog">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between mb-5">
        <h3 id="cat-dialog-title" class="text-base font-semibold text-white">Nueva Categoría</h3>
        <button id="close-cat-dialog" class="btn-icon btn-icon-red">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="category-form" class="space-y-4" novalidate>
        <input type="hidden" id="cat-id" />
        <div>
          <label class="form-label">Nombre <span class="text-red-400">*</span></label>
          <input id="cat-name" type="text" class="form-input" placeholder="Pods, Desechables…" required />
        </div>
        <div>
          <label class="form-label">Orden de Despliegue <span class="text-red-400">*</span></label>
          <input id="cat-order" type="number" min="0" class="form-input" placeholder="1" value="1" required />
        </div>
        <div id="cat-form-error" class="hidden rounded-lg px-4 py-3 text-sm text-red-400 bg-red-400/10 border border-red-400/25"></div>
        <div class="flex gap-3 justify-end pt-1">
          <button type="button" id="cancel-cat-dialog" class="btn-secondary">Cancelar</button>
          <button type="submit" id="submit-cat" class="btn-primary">
            <span id="cat-submit-text">Crear</span>
          </button>
        </div>
      </form>
    </div>
  </dialog>

  <dialog id="delete-cat-dialog">
    <div class="modal-box max-w-sm text-center">
      <div class="w-14 h-14 rounded-full bg-red-500/15 border border-red-500/25 flex items-center justify-center mx-auto mb-4">
        <svg width="24" height="24" fill="none" stroke="#f87171" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
      </div>
      <h3 class="text-base font-semibold text-white mb-2">Eliminar Categoría</h3>
      <p class="text-sm text-slate-400 mb-6">La categoría será desactivada del sistema.</p>
      <input type="hidden" id="delete-cat-id" />
      <div class="flex gap-3 justify-center">
        <button id="cancel-delete-cat" class="btn-secondary">Cancelar</button>
        <button id="confirm-delete-cat" class="btn-danger py-2.5 px-5">Eliminar</button>
      </div>
    </div>
  </dialog>

  <!-- Atributo Create / Edit Dialog -->
  <dialog id="attr-dialog">
    <div class="modal-box max-w-sm">
      <div class="flex items-center justify-between mb-5">
        <h3 id="attr-dialog-title" class="text-base font-semibold text-white">Nuevo Atributo</h3>
        <button id="close-attr-dialog" class="btn-icon btn-icon-red">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="attr-form" class="space-y-4" novalidate>
        <input type="hidden" id="attr-id" />
        <div>
          <label class="form-label">Nombre <span class="text-red-400">*</span></label>
          <input id="attr-name" type="text" class="form-input" placeholder="Ej: Talla, Color…" required />
        </div>
        <div id="attr-form-error" class="hidden rounded-lg px-4 py-3 text-sm text-red-400 bg-red-400/10 border border-red-400/25"></div>
        <div class="flex gap-3 justify-end pt-1">
          <button type="button" id="cancel-attr-dialog" class="btn-secondary">Cancelar</button>
          <button type="submit" id="submit-attr" class="btn-primary">
            <span id="attr-submit-text">Crear</span>
          </button>
        </div>
      </form>
    </div>
  </dialog>

  <!-- Atributo Delete Dialog -->
  <dialog id="delete-attr-dialog">
    <div class="modal-box max-w-sm text-center">
      <div class="w-14 h-14 rounded-full bg-red-500/15 border border-red-500/25 flex items-center justify-center mx-auto mb-4">
        <svg width="24" height="24" fill="none" stroke="#f87171" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
      </div>
      <h3 class="text-base font-semibold text-white mb-2">Eliminar Atributo</h3>
      <p class="text-sm text-slate-400 mb-6">El atributo será desactivado del sistema.</p>
      <input type="hidden" id="delete-attr-id" />
      <div class="flex gap-3 justify-center">
        <button id="cancel-delete-attr" class="btn-secondary">Cancelar</button>
        <button id="confirm-delete-attr" class="btn-danger py-2.5 px-5">Eliminar</button>
      </div>
    </div>
  </dialog>

  <script>
    import { api, showToast } from '../utils/api.ts';

    interface Category { id: string; name: string; display_order: number; }
    interface Product { id: string; name: string; }
    interface Attribute { id: string; name: string; is_active: number; created_at: string; updated_at: string; }

    async function loadCategories() {
      const tbody = document.getElementById('categories-body')!;
      try {
        const res = await api.get<Category[]>('/categories');
        const cats = res.data as Category[];
        if (cats.length === 0) {
          tbody.innerHTML = '<tr><td colspan="4" class="text-center py-10 text-slate-500">No hay categorías registradas.</td></tr>';
          return;
        }

        let idx = 1;
        tbody.innerHTML = cats.map(c => {
          return `
          <tr>
            <td class="text-slate-600 font-mono text-xs">${idx++}</td>
            <td class="font-medium text-white">${c.name}</td>
            <td><span class="text-xs bg-slate-800 text-slate-400 rounded px-2 py-0.5">${c.display_order}</span></td>
            <td>
              <div class="flex gap-1.5 justify-end">
                <button class="btn-icon btn-icon-teal edit-cat-btn" data-id="${c.id}" data-name="${c.name}" data-order="${c.display_order}" title="Editar">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn-icon btn-icon-red delete-cat-btn" data-id="${c.id}" title="Eliminar">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
              </div>
            </td>
          </tr>
        `}).join('');

        document.querySelectorAll('.edit-cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const el = btn as HTMLElement;
            (document.getElementById('cat-dialog-title')!).textContent = 'Editar Categoría';
            (document.getElementById('cat-submit-text')!).textContent = 'Guardar';
            (document.getElementById('cat-id') as HTMLInputElement).value = el.dataset.id!;
            (document.getElementById('cat-name') as HTMLInputElement).value = el.dataset.name!;
            (document.getElementById('cat-order') as HTMLInputElement).value = el.dataset.order!;
            (document.getElementById('cat-form-error')!).classList.add('hidden');
            (document.getElementById('category-dialog') as HTMLDialogElement).showModal();
          });
        });

        document.querySelectorAll('.delete-cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            (document.getElementById('delete-cat-id') as HTMLInputElement).value = (btn as HTMLElement).dataset.id!;
            (document.getElementById('delete-cat-dialog') as HTMLDialogElement).showModal();
          });
        });
      } catch (err: unknown) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center py-10 text-red-400 text-sm">${err instanceof Error ? err.message : 'Error'}</td></tr>`;
      }
    }

    async function loadAttributes() {
      const tbody = document.getElementById('attributes-body')!;
      try {
        const res = await api.get<Attribute[]>('/attributes');
        const attrs = res.data as Attribute[];
        if (attrs.length === 0) {
          tbody.innerHTML = '<tr><td colspan="4" class="text-center py-10 text-slate-500">No hay atributos.</td></tr>';
          return;
        }

        let idx = 1;
        tbody.innerHTML = attrs.map(a => `
          <tr>
            <td class="text-slate-600 font-mono text-xs">${idx++}</td>
            <td class="font-medium text-white">${a.name}</td>
            <td>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium ${a.is_active ? 'badge-delivered' : 'badge-cancelled'}">
                ${a.is_active ? 'Activo' : 'Inactivo'}
              </span>
            </td>
            <td>
              <div class="flex gap-1.5 justify-end">
                <button class="btn-icon btn-icon-teal edit-attr-btn" data-id="${a.id}" data-name="${a.name}" title="Editar">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn-icon btn-icon-red delete-attr-btn" data-id="${a.id}" title="Eliminar">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                </button>
              </div>
            </td>
          </tr>
        `).join('');

        document.querySelectorAll('.edit-attr-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const el = btn as HTMLElement;
            (document.getElementById('attr-dialog-title')!).textContent = 'Editar Atributo';
            (document.getElementById('attr-submit-text')!).textContent = 'Guardar';
            (document.getElementById('attr-id') as HTMLInputElement).value = el.dataset.id!;
            (document.getElementById('attr-name') as HTMLInputElement).value = el.dataset.name!;
            (document.getElementById('attr-form-error')!).classList.add('hidden');
            (document.getElementById('attr-dialog') as HTMLDialogElement).showModal();
          });
        });

        document.querySelectorAll('.delete-attr-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            (document.getElementById('delete-attr-id') as HTMLInputElement).value = (btn as HTMLElement).dataset.id!;
            (document.getElementById('delete-attr-dialog') as HTMLDialogElement).showModal();
          });
        });
      } catch (err: unknown) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center py-10 text-red-400 text-sm">Error</td></tr>`;
      }
    }

    document.addEventListener('astro:page-load', () => {
      if (window.location.pathname !== '/categories') return;
      loadCategories();
      loadAttributes();

      // CATEGORIES LOGIC
      document.getElementById('btn-new-category')?.addEventListener('click', () => {
        (document.getElementById('cat-dialog-title')!).textContent = 'Nueva Categoría';
        (document.getElementById('cat-submit-text')!).textContent = 'Crear';
        (document.getElementById('cat-id') as HTMLInputElement).value = '';
        (document.getElementById('category-form') as HTMLFormElement).reset();
        (document.getElementById('cat-form-error')!).classList.add('hidden');
        (document.getElementById('category-dialog') as HTMLDialogElement).showModal();
      });

      const closeCatDialog = () => (document.getElementById('category-dialog') as HTMLDialogElement).close();
      document.getElementById('close-cat-dialog')?.addEventListener('click', closeCatDialog);
      document.getElementById('cancel-cat-dialog')?.addEventListener('click', closeCatDialog);
      document.getElementById('category-dialog')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeCatDialog(); });

      document.getElementById('category-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const errBox = document.getElementById('cat-form-error')!;
        errBox.classList.add('hidden');
        const id = (document.getElementById('cat-id') as HTMLInputElement).value;
        const name = (document.getElementById('cat-name') as HTMLInputElement).value.trim();
        const display_order = parseInt((document.getElementById('cat-order') as HTMLInputElement).value);
        const btn = document.getElementById('submit-cat') as HTMLButtonElement;
        btn.disabled = true;
        try {
          if (id) { await api.put(`/categories/${id}`, { name, display_order }); showToast('Categoría actualizada', 'success'); }
          else { await api.post('/categories', { name, display_order }); showToast('Categoría creada', 'success'); }
          closeCatDialog();
          loadCategories();
        } catch (err: unknown) {
          errBox.textContent = err instanceof Error ? err.message : 'Error';
          errBox.classList.remove('hidden');
        } finally { btn.disabled = false; }
      });

      document.getElementById('cancel-delete-cat')?.addEventListener('click', () => (document.getElementById('delete-cat-dialog') as HTMLDialogElement).close());
      document.getElementById('delete-cat-dialog')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) (document.getElementById('delete-cat-dialog') as HTMLDialogElement).close(); });
      document.getElementById('confirm-delete-cat')?.addEventListener('click', async () => {
        const id = (document.getElementById('delete-cat-id') as HTMLInputElement).value;
        try {
          await api.delete(`/categories/${id}`);
          showToast('Categoría eliminada', 'success');
          (document.getElementById('delete-cat-dialog') as HTMLDialogElement).close();
          loadCategories();
        } catch (err: unknown) { showToast(err instanceof Error ? err.message : 'Error', 'error'); }
      });

      // ATTRIBUTES LOGIC
      document.getElementById('btn-new-attr')?.addEventListener('click', () => {
        (document.getElementById('attr-dialog-title')!).textContent = 'Nuevo Atributo';
        (document.getElementById('attr-submit-text')!).textContent = 'Crear';
        (document.getElementById('attr-id') as HTMLInputElement).value = '';
        (document.getElementById('attr-form') as HTMLFormElement).reset();
        (document.getElementById('attr-form-error')!).classList.add('hidden');
        (document.getElementById('attr-dialog') as HTMLDialogElement).showModal();
      });

      const closeAttrDialog = () => (document.getElementById('attr-dialog') as HTMLDialogElement).close();
      document.getElementById('close-attr-dialog')?.addEventListener('click', closeAttrDialog);
      document.getElementById('cancel-attr-dialog')?.addEventListener('click', closeAttrDialog);
      document.getElementById('attr-dialog')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeAttrDialog(); });

      document.getElementById('attr-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const errBox = document.getElementById('attr-form-error')!;
        errBox.classList.add('hidden');
        const id = (document.getElementById('attr-id') as HTMLInputElement).value;
        const name = (document.getElementById('attr-name') as HTMLInputElement).value.trim();
        const btn = document.getElementById('submit-attr') as HTMLButtonElement;
        btn.disabled = true;
        try {
          if (id) { await api.put(`/attributes/${id}`, { name }); showToast('Atributo actualizado', 'success'); }
          else { await api.post('/attributes', { name }); showToast('Atributo creado', 'success'); }
          closeAttrDialog();
          loadAttributes();
        } catch (err: unknown) {
          errBox.textContent = err instanceof Error ? err.message : 'Error';
          errBox.classList.remove('hidden');
        } finally { btn.disabled = false; }
      });

      document.getElementById('cancel-delete-attr')?.addEventListener('click', () => (document.getElementById('delete-attr-dialog') as HTMLDialogElement).close());
      document.getElementById('delete-attr-dialog')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) (document.getElementById('delete-attr-dialog') as HTMLDialogElement).close(); });
      document.getElementById('confirm-delete-attr')?.addEventListener('click', async () => {
        const id = (document.getElementById('delete-attr-id') as HTMLInputElement).value;
        try {
          await api.delete(`/attributes/${id}`);
          showToast('Atributo eliminado', 'success');
          (document.getElementById('delete-attr-dialog') as HTMLDialogElement).close();
          loadAttributes();
        } catch (err: unknown) { showToast(err instanceof Error ? err.message : 'Error', 'error'); }
      });

    });
  </script>
</Layout>
