---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Clientes" activeNav="customers">
    <div class="space-y-5">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h2 class="text-xl font-bold text-white">Clientes</h2>
                <p class="text-sm text-slate-500 mt-0.5">
                    Directorio y perfiles del CRM de Ecommerce
                </p>
            </div>
        </div>

        <!-- Search -->
        <div class="glass-card rounded-xl px-5 py-4">
            <div class="relative max-w-sm">
                <input
                    id="customer-search"
                    type="text"
                    placeholder="Buscar cliente…"
                    class="form-input pl-8 text-sm"
                />
            </div>
        </div>

        <div class="glass-card rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="cms-table">
                    <thead
                        ><tr>
                            <th>Cliente</th><th>Ciudad</th><th>Estado</th><th
                                >País</th
                            ><th>Teléfono</th><th class="text-right"
                                >Acciones</th
                            >
                        </tr></thead
                    >
                    <tbody id="customers-body">
                        <tr
                            ><td
                                colspan="6"
                                class="text-center py-10 text-slate-500"
                                >Cargando clientes...</td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Customer detail dialog -->
    <dialog id="customer-dialog">
        <div class="modal-box max-w-lg">
            <div class="flex items-center justify-between mb-5">
                <h3 class="text-base font-semibold text-white">
                    Perfil del Cliente
                </h3>
                <button
                    id="close-customer-dialog"
                    class="btn-icon btn-icon-red"
                >
                    <svg
                        width="14"
                        height="14"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                        ><path d="M18 6 6 18M6 6l12 12"></path></svg
                    >
                </button>
            </div>
            <div id="customer-detail-content" class="space-y-4">
                <p class="text-sm text-slate-500">Cargando...</p>
            </div>
        </div>
    </dialog>

    <!-- Soft delete dialog -->
    <dialog id="deactivate-customer-dialog">
        <div class="modal-box max-w-sm text-center">
            <div
                class="w-14 h-14 rounded-full bg-red-500/15 border border-red-500/25 flex items-center justify-center mx-auto mb-4"
            >
                <svg
                    width="24"
                    height="24"
                    fill="none"
                    stroke="#f87171"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                    ></path><circle cx="9" cy="7" r="4"></circle>
                    <line x1="23" y1="18" x2="17" y2="12"></line><line
                        x1="17"
                        y1="18"
                        x2="23"
                        y2="12"></line>
                </svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">
                Desactivar Cliente
            </h3>
            <p class="text-sm text-slate-400 mb-6">
                El perfil del cliente será desactivado (Soft Delete). La cuenta
                de acceso permanecerá intacta.
            </p>
            <input type="hidden" id="deactivate-customer-id" />
            <div class="flex gap-3 justify-center">
                <button id="cancel-deactivate" class="btn-secondary"
                    >Cancelar</button
                >
                <button id="confirm-deactivate" class="btn-danger py-2.5 px-5"
                    >Desactivar</button
                >
            </div>
        </div>
    </dialog>

    <script>
        import { api, showToast } from "../utils/api.ts";

        interface Customer {
            id: string;
            first_name: string;
            last_name: string;
            phone?: string;
            city?: string;
            state?: string;
            country?: string;
            street_address?: string;
            exterior_number?: string;
            interior_number?: string;
            neighborhood?: string;
            postal_code?: string;
            is_active?: boolean;
        }

        let allCustomers: Customer[] = [];

        function renderTable(customers: Customer[]) {
            const tbody = document.getElementById("customers-body")!;
            if (customers.length === 0) {
                tbody.innerHTML =
                    '<tr><td colspan="6" class="text-center py-10 text-slate-500">No se encontraron clientes.</td></tr>';
                return;
            }
            tbody.innerHTML = customers
                .map((c) => {
                    const initials =
                        `${c.first_name.charAt(0)}${c.last_name.charAt(0)}`.toUpperCase();
                    return `
          <tr>
            <td>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center text-xs font-bold text-white shrink-0">${initials}</div>
                <div>
                  <p class="font-medium text-white text-sm">${c.first_name} ${c.last_name}</p>
                  <span class="text-xs ${c.is_active === false ? "text-red-400" : "text-teal-400"}">${c.is_active === false ? "● Inactivo" : "● Activo"}</span>
                </div>
              </div>
            </td>
            <td class="text-slate-400 text-sm">${c.city ?? "—"}</td>
            <td class="text-slate-400 text-sm">${c.state ?? "—"}</td>
            <td class="text-slate-400 text-sm">${c.country ?? "—"}</td>
            <td class="font-mono text-xs text-slate-400">${c.phone ?? "—"}</td>
            <td>
              <div class="flex gap-1.5 justify-end">
                <button class="btn-icon btn-icon-teal view-customer-btn" data-id="${c.id}" title="Ver perfil">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
                ${
                    c.is_active !== false
                        ? `
                <button class="btn-icon btn-icon-red deactivate-btn" data-id="${c.id}" title="Desactivar">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <line x1="23" y1="18" x2="17" y2="12"/><line x1="17" y1="18" x2="23" y2="12"/>
                  </svg>
                </button>`
                        : ""
                }
              </div>
            </td>
          </tr>
        `;
                })
                .join("");

            document.querySelectorAll(".view-customer-btn").forEach((btn) => {
                btn.addEventListener("click", () =>
                    openCustomerDetail((btn as HTMLElement).dataset.id!),
                );
            });
            document.querySelectorAll(".deactivate-btn").forEach((btn) => {
                btn.addEventListener("click", () => {
                    (
                        document.getElementById(
                            "deactivate-customer-id",
                        ) as HTMLInputElement
                    ).value = (btn as HTMLElement).dataset.id!;
                    (
                        document.getElementById(
                            "deactivate-customer-dialog",
                        ) as HTMLDialogElement
                    ).showModal();
                });
            });
        }

        async function loadCustomers() {
            try {
                const res = await api.get<Customer[]>("/customers");
                allCustomers = res.data as Customer[];
                renderTable(allCustomers);
            } catch (err: unknown) {
                document.getElementById("customers-body")!.innerHTML =
                    `<tr><td colspan="6" class="text-center py-10 text-red-400 text-sm">${err instanceof Error ? err.message : "Error"}</td></tr>`;
            }
        }

        async function openCustomerDetail(id: string) {
            const content = document.getElementById("customer-detail-content")!;
            content.innerHTML =
                '<p class="text-sm text-slate-500">Cargando...</p>';
            (
                document.getElementById("customer-dialog") as HTMLDialogElement
            ).showModal();
            try {
                const res = await api.get<Customer>(`/customers/${id}`);
                const c = res.data as Customer;
                const address = [
                    c.street_address,
                    c.exterior_number,
                    c.interior_number,
                    c.neighborhood,
                    c.postal_code,
                    c.city,
                    c.state,
                    c.country,
                ]
                    .filter(Boolean)
                    .join(", ");
                content.innerHTML = `
          <div class="flex items-center gap-4 mb-5">
            <div class="w-14 h-14 rounded-full bg-gradient-brand flex items-center justify-center text-xl font-bold text-white shrink-0">
              ${c.first_name.charAt(0)}${c.last_name.charAt(0)}
            </div>
            <div>
              <h4 class="text-lg font-bold text-white">${c.first_name} ${c.last_name}</h4>
              <span class="text-xs ${c.is_active === false ? "text-red-400" : "text-teal-400"}">${c.is_active === false ? "● Inactivo" : "● Activo"}</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">Teléfono de Envío</p>
              <p class="text-sm font-mono text-slate-200">${c.phone ?? "—"}</p>
            </div>
            <div class="glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">Ciudad</p>
              <p class="text-sm text-slate-200">${c.city ?? "—"}</p>
            </div>
            <div class="glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">Colonia / Barrio</p>
              <p class="text-sm text-slate-200">${c.neighborhood ?? "—"}</p>
            </div>
            <div class="glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">Código Postal</p>
              <p class="text-sm font-mono text-slate-200">${c.postal_code ?? "—"}</p>
            </div>
            <div class="col-span-2 glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">Dirección de Envío</p>
              <p class="text-sm text-slate-200">${address || "—"}</p>
            </div>
            <div class="glass-card rounded-lg p-3">
              <p class="text-xs text-slate-500 mb-1">ID del Cliente</p>
              <p class="text-xs font-mono text-slate-500">${c.id}</p>
            </div>
          </div>
        `;
            } catch (err: unknown) {
                content.innerHTML = `<p class="text-red-400 text-sm">${err instanceof Error ? err.message : "Error"}</p>`;
            }
        }

        document.addEventListener("astro:page-load", () => {
            if (!window.location.pathname.startsWith("/customers")) return;
            loadCustomers();

            // Search
            let searchTimer: ReturnType<typeof setTimeout>;
            document
                .getElementById("customer-search")
                ?.addEventListener("input", (e) => {
                    clearTimeout(searchTimer);
                    searchTimer = setTimeout(() => {
                        const q = (
                            e.target as HTMLInputElement
                        ).value.toLowerCase();
                        renderTable(
                            allCustomers.filter(
                                (c) =>
                                    `${c.first_name} ${c.last_name}`
                                        .toLowerCase()
                                        .includes(q) ||
                                    (c.city ?? "").toLowerCase().includes(q) ||
                                    (c.phone ?? "").includes(q),
                            ),
                        );
                    }, 300);
                });

            // Customer dialog
            document
                .getElementById("close-customer-dialog")
                ?.addEventListener("click", () =>
                    (
                        document.getElementById(
                            "customer-dialog",
                        ) as HTMLDialogElement
                    ).close(),
                );
            document
                .getElementById("customer-dialog")
                ?.addEventListener("click", (e) => {
                    if (e.target === e.currentTarget)
                        (
                            document.getElementById(
                                "customer-dialog",
                            ) as HTMLDialogElement
                        ).close();
                });

            // Deactivate dialog
            document
                .getElementById("cancel-deactivate")
                ?.addEventListener("click", () =>
                    (
                        document.getElementById(
                            "deactivate-customer-dialog",
                        ) as HTMLDialogElement
                    ).close(),
                );
            document
                .getElementById("deactivate-customer-dialog")
                ?.addEventListener("click", (e) => {
                    if (e.target === e.currentTarget)
                        (
                            document.getElementById(
                                "deactivate-customer-dialog",
                            ) as HTMLDialogElement
                        ).close();
                });
            document
                .getElementById("confirm-deactivate")
                ?.addEventListener("click", async () => {
                    const id = (
                        document.getElementById(
                            "deactivate-customer-id",
                        ) as HTMLInputElement
                    ).value;
                    try {
                        await api.delete(`/customers/${id}`);
                        showToast("Cliente desactivado", "success");
                        (
                            document.getElementById(
                                "deactivate-customer-dialog",
                            ) as HTMLDialogElement
                        ).close();
                        loadCustomers();
                    } catch (err: unknown) {
                        showToast(
                            err instanceof Error ? err.message : "Error",
                            "error",
                        );
                    }
                });
        });
    </script>
</Layout>
