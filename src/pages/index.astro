---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard" activeNav="dashboard">
  <div class="space-y-6">
    
    <!-- Page header -->
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold text-white text-glow-teal">Panel de Control</h2>
        <p class="text-sm text-slate-500 mt-0.5">Vista general del sistema</p>
      </div>
      <div class="text-xs text-slate-600 bg-slate-900/60 border border-slate-800 rounded-lg px-3 py-2">
        <span id="dashboard-date">Cargando...</span>
      </div>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" id="stats-grid">
      <!-- Skeleton cards -->
      {[1,2,3,4].map(() => (
        <div class="glass-card rounded-xl p-5">
          <div class="skeleton h-4 w-24 mb-3 rounded"></div>
          <div class="skeleton h-8 w-16 mb-2 rounded"></div>
          <div class="skeleton h-3 w-20 rounded"></div>
        </div>
      ))}
    </div>


    <!-- Recent orders table -->
    <div class="glass-card rounded-xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-teal-900/20">
        <h3 class="text-sm font-semibold text-white">Pedidos Recientes</h3>
        <a href="/orders" class="text-xs text-teal-400 hover:text-teal-300 transition-colors">Ver todos →</a>
      </div>
      <div id="recent-orders-container" class="px-5 py-4">
        <p class="text-sm text-slate-500 text-center py-6">Cargando pedidos...</p>
      </div>
    </div>
  </div>

  <script>
    import { api, showToast } from '../utils/api.ts';

    interface Order {
      id: string;
      status: string;
      total: number;
      created_at: string;
    }
    interface Product { id: string; is_active: boolean; }
    interface Customer { id: string; }
    interface Banner { id: string; }

    const statusLabels: Record<string, string> = {
      pending: 'Pendiente', confirmed: 'Confirmado',
      shipped: 'Enviado',   delivered: 'Entregado', cancelled: 'Cancelado',
    };
    const statusBadge: Record<string, string> = {
      pending: 'badge-pending', confirmed: 'badge-confirmed',
      shipped: 'badge-shipped', delivered: 'badge-delivered', cancelled: 'badge-cancelled',
    };

    document.addEventListener('astro:page-load', async () => {
      if (window.location.pathname !== '/') return;

      // Date
      const dateEl = document.getElementById('dashboard-date');
      if (dateEl) {
        dateEl.textContent = new Date().toLocaleDateString('es-MX', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
        });
      }


      // Load stats in parallel
      const [ordersRes, productsRes, customersRes, bannersRes] = await Promise.allSettled([
        api.get<Order[]>('/orders'),
        api.get<{ data: Product[]; pagination: { total: number } }>('/products?limit=100'),
        api.get<Customer[]>('/customers'),
        api.get<Banner[]>('/header-images'),
      ]);

      const orders    = ordersRes.status === 'fulfilled' ? (ordersRes.value.data as Order[]) : [];
      const prodTotal = productsRes.status === 'fulfilled'
        ? (productsRes.value.pagination?.total ?? (productsRes.value.data as Product[]).length)
        : 0;
      const customers  = customersRes.status === 'fulfilled' ? (customersRes.value.data as Customer[]) : [];
      const banners    = bannersRes.status === 'fulfilled' ? (bannersRes.value.data as Banner[]) : [];
      const pendingOrders = (orders as Order[]).filter((o: Order) => o.status === 'pending').length;

      const statsGrid = document.getElementById('stats-grid');
      if (statsGrid) {
        const stats = [
          { label: 'Pedidos Pendientes', value: pendingOrders, sub: 'requieren atención', color: 'text-yellow-400', bg: 'rgba(234,179,8,0.08)', border: 'rgba(234,179,8,0.2)', icon: '📋' },
          { label: 'Total Productos',    value: prodTotal,     sub: 'en catálogo',       color: 'text-teal-400',   bg: 'rgba(45,212,191,0.06)', border: 'rgba(45,212,191,0.15)', icon: '📦' },
          { label: 'Clientes Activos',   value: customers.length, sub: 'registrados',   color: 'text-blue-400',   bg: 'rgba(59,130,246,0.06)', border: 'rgba(59,130,246,0.15)', icon: '👥' },
          { label: 'Banners Activos',    value: banners.length, sub: 'en carrusel',     color: 'text-purple-400', bg: 'rgba(168,85,247,0.06)', border: 'rgba(168,85,247,0.15)', icon: '🖼️' },
        ];
        statsGrid.innerHTML = stats.map(s => `
          <div class="rounded-xl p-5 border" style="background:${s.bg};border-color:${s.border}">
            <div class="flex items-center justify-between mb-3">
              <p class="text-xs font-medium text-slate-400">${s.label}</p>
              <span class="text-xl">${s.icon}</span>
            </div>
            <p class="text-3xl font-bold ${s.color} mb-1">${s.value}</p>
            <p class="text-xs text-slate-500">${s.sub}</p>
          </div>
        `).join('');
      }

      // Update sidebar pending badge
      const badge = document.getElementById('sidebar-pending-badge');
      if (badge && pendingOrders > 0) {
        badge.textContent = String(pendingOrders);
        badge.classList.remove('hidden');
      }

      // Recent orders table
      const container = document.getElementById('recent-orders-container');
      if (container) {
        const recent = (orders as Order[]).slice(0, 8);
        if (recent.length === 0) {
          container.innerHTML = '<p class="text-sm text-slate-500 text-center py-6">No hay pedidos registrados aún.</p>';
        } else {
          container.innerHTML = `
            <table class="cms-table">
              <thead><tr>
                <th>ID</th><th>Estado</th><th>Total</th><th>Fecha</th>
              </tr></thead>
              <tbody>
                ${recent.map((o: Order) => `
                  <tr class="cursor-pointer" onclick="window.location.href='/orders'">
                    <td class="font-mono text-xs text-slate-400">${o.id.slice(0,8)}…</td>
                    <td><span class="text-xs px-2 py-0.5 rounded-full font-medium ${statusBadge[o.status] ?? ''}">${statusLabels[o.status] ?? o.status}</span></td>
                    <td class="font-semibold text-white">$${Number(o.total).toLocaleString('es-MX', {minimumFractionDigits:2})}</td>
                    <td class="text-slate-500">${new Date(o.created_at).toLocaleDateString('es-MX')}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          `;
        }
      }
    });
  </script>
</Layout>
