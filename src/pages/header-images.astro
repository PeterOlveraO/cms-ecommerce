---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Banners" activeNav="header-images">
    <div class="space-y-5">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h2 class="text-xl font-bold text-white">
                    Banners del Carrusel
                </h2>
                <p class="text-sm text-slate-500 mt-0.5">
                    Gestiona las imágenes publicitarias del header de la tienda
                </p>
            </div>
            <button id="btn-new-banner" class="btn-primary">
                <svg
                    width="16"
                    height="16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg
                >
                Nuevo Banner
            </button>
        </div>

        <!-- Gallery grid -->
        <div
            id="banners-grid"
            class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4"
        >
            <div class="col-span-full text-center py-10 text-slate-500 text-sm">
                Cargando banners...
            </div>
        </div>
    </div>

    <dialog id="banner-dialog">
        <div class="modal-box max-w-md">
            <div class="flex items-center justify-between mb-5">
                <h3
                    id="banner-dialog-title"
                    class="text-base font-semibold text-white"
                >
                    Nuevo Banner
                </h3>
                <button id="close-banner-dialog" class="btn-icon btn-icon-red">
                    <svg
                        width="14"
                        height="14"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                        ><path d="M18 6 6 18M6 6l12 12"></path></svg
                    >
                </button>
            </div>
            <form id="banner-form" class="space-y-4" novalidate>
                <input type="hidden" id="banner-id" />
                <div>
                    <label class="form-label"
                        >Nombre del Banner <span class="text-red-400">*</span
                        ></label
                    >
                    <input
                        id="b-name"
                        type="text"
                        class="form-input"
                        placeholder="Banner Verano 2025"
                        required
                    />
                </div>
                <div>
                    <label class="form-label"
                        >Imagen del Banner <span class="text-red-400">*</span
                        ></label
                    >
                    <!-- Hidden field that holds the final URL -->
                    <input type="hidden" id="b-image-url" />

                    <!-- Preview -->
                    <div id="b-image-preview-wrap" class="hidden mb-2 relative">
                        <img
                            id="b-image-preview"
                            src=""
                            alt="Preview"
                            class="w-full h-28 object-cover rounded-lg bg-slate-800 border border-teal-900/30"
                        />
                        <button
                            type="button"
                            id="b-image-clear"
                            class="absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-black/70 text-slate-300 hover:text-white flex items-center justify-center text-xs leading-none"
                            title="Quitar imagen">✕</button
                        >
                    </div>

                    <!-- File picker -->
                    <label
                        id="b-image-file-label"
                        class="flex items-center gap-2 cursor-pointer btn-secondary w-full text-xs py-2 mb-2"
                    >
                        <svg
                            width="14"
                            height="14"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                            ></path><polyline points="17 8 12 3 7 8"
                            ></polyline><line x1="12" y1="3" x2="12" y2="15"
                            ></line></svg
                        >
                        <span id="b-image-file-label-text"
                            >Seleccionar archivo…</span
                        >
                        <input
                            id="b-image-file"
                            type="file"
                            accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                            class="sr-only"
                        />
                    </label>

                    <!-- URL manual fallback -->
                    <input
                        id="b-image-url-manual"
                        type="url"
                        class="form-input text-xs"
                        placeholder="O pega una URL externa…"
                    />
                </div>
                <div class="relative">
                    <label class="form-label">Enlace a Producto (opcional)</label>
                    <input
                        id="b-link-search"
                        type="text"
                        class="form-input"
                        placeholder="Buscar producto por nombre..."
                        autocomplete="off"
                    />
                    <input type="hidden" id="b-link-url" />
                    <div id="b-link-dropdown" class="absolute z-50 left-0 right-0 top-full mt-1 bg-surface-800 border border-teal-900/30 rounded-lg shadow-xl hidden overflow-hidden">
                        <ul id="b-link-results" class="max-h-48 overflow-y-auto"></ul>
                    </div>
                </div>
                <div>
                    <label class="form-label"
                        >Orden de Despliegue <span class="text-red-400">*</span
                        ></label
                    >
                    <input
                        id="b-order"
                        type="number"
                        min="0"
                        class="form-input"
                        placeholder="0"
                        value="0"
                        required
                    />
                </div>
                <div
                    id="banner-form-error"
                    class="hidden rounded-lg px-4 py-3 text-sm text-red-400 bg-red-400/10 border border-red-400/25"
                >
                </div>
                <div class="flex gap-3 justify-end pt-1">
                    <button
                        type="button"
                        id="cancel-banner-dialog"
                        class="btn-secondary">Cancelar</button
                    >
                    <button type="submit" id="submit-banner" class="btn-primary"
                        ><span id="banner-submit-text">Crear Banner</span
                        ></button
                    >
                </div>
            </form>
        </div>
    </dialog>

    <dialog id="delete-banner-dialog">
        <div class="modal-box max-w-sm text-center">
            <div
                class="w-14 h-14 rounded-full bg-red-500/15 border border-red-500/25 flex items-center justify-center mx-auto mb-4"
            >
                <svg
                    width="24"
                    height="24"
                    fill="none"
                    stroke="#f87171"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    ><polyline points="3 6 5 6 21 6"></polyline><path
                        d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"
                    ></path></svg
                >
            </div>
            <h3 class="text-base font-semibold text-white mb-2">
                Eliminar Banner
            </h3>
            <p class="text-sm text-slate-400 mb-6">
                El banner será eliminado del carrusel.
            </p>
            <input type="hidden" id="delete-banner-id" />
            <div class="flex gap-3 justify-center">
                <button id="cancel-delete-banner" class="btn-secondary"
                    >Cancelar</button
                >
                <button
                    id="confirm-delete-banner"
                    class="btn-danger py-2.5 px-5">Eliminar</button
                >
            </div>
        </div>
    </dialog>

    <script>
        import { api, uploadImage, showToast } from "../utils/api.ts";

        interface Banner {
            id: string;
            name: string;
            image_url: string;
            link_url?: string;
            display_order: number;
        }

        async function loadBanners() {
            const grid = document.getElementById("banners-grid")!;
            try {
                const res = await api.get<Banner[]>("/header-images");
                const banners = res.data as Banner[];
                if (banners.length === 0) {
                    grid.innerHTML =
                        '<div class="col-span-full text-center py-10 text-slate-500 text-sm">No hay banners registrados.</div>';
                    return;
                }
                grid.innerHTML = banners
                    .map(
                        (b) => `
          <div class="glass-card-hover rounded-xl overflow-hidden group">
            <div class="relative">
              <img src="${b.image_url}" alt="${b.name}" class="w-full h-44 object-cover bg-slate-800"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              <div class="hidden w-full h-44 bg-slate-800 items-center justify-center text-slate-600 text-sm">Sin imagen</div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <span class="absolute top-2 right-2 text-xs bg-black/60 text-slate-300 px-2 py-0.5 rounded-full">Orden: ${b.display_order}</span>
            </div>
            <div class="p-4">
              <h4 class="font-semibold text-white text-sm mb-1">${b.name}</h4>
              ${b.link_url ? `<p class="text-xs text-teal-400 truncate mb-3">${b.link_url}</p>` : `<p class="text-xs text-slate-600 mb-3">Sin enlace</p>`}
              <div class="flex gap-2">
                <button class="btn-icon btn-icon-teal flex-1 edit-banner-btn" data-id="${b.id}" data-name="${b.name}" data-image="${b.image_url}" data-link="${b.link_url ?? ""}" data-order="${b.display_order}">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  <span class="text-xs">Editar</span>
                </button>
                <button class="btn-icon btn-icon-red delete-banner-btn" data-id="${b.id}">
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
              </div>
            </div>
          </div>
        `,
                    )
                    .join("");

                document.querySelectorAll(".edit-banner-btn").forEach((btn) => {
                    btn.addEventListener("click", () => {
                        const el = btn as HTMLElement;
                        document.getElementById(
                            "banner-dialog-title",
                        )!.textContent = "Editar Banner";
                        document.getElementById(
                            "banner-submit-text",
                        )!.textContent = "Guardar";
                        (
                            document.getElementById(
                                "banner-id",
                            ) as HTMLInputElement
                        ).value = el.dataset.id!;
                        (
                            document.getElementById(
                                "b-name",
                            ) as HTMLInputElement
                        ).value = el.dataset.name!;
                        // Populate image picker with existing URL
                        const existingImg = el.dataset.image!;
                        (
                            document.getElementById(
                                "b-image-url",
                            ) as HTMLInputElement
                        ).value = existingImg;
                        (
                            document.getElementById(
                                "b-image-url-manual",
                            ) as HTMLInputElement
                        ).value = existingImg;
                        const bPrevWrap = document.getElementById(
                            "b-image-preview-wrap",
                        )!;
                        const bPrevImg = document.getElementById(
                            "b-image-preview",
                        ) as HTMLImageElement;
                        const bLabelTx = document.getElementById(
                            "b-image-file-label-text",
                        )!;
                        if (existingImg) {
                            bPrevImg.src = existingImg;
                            bPrevWrap.classList.remove("hidden");
                            bLabelTx.textContent = "Cambiar archivo…";
                        } else {
                            bPrevWrap.classList.add("hidden");
                            bLabelTx.textContent = "Seleccionar archivo…";
                        }
                        const linkUrl = el.dataset.link!;
                        const hiddenLinkInput = document.getElementById("b-link-url") as HTMLInputElement;
                        const searchInput = document.getElementById("b-link-search") as HTMLInputElement;
                        hiddenLinkInput.value = linkUrl;
                        searchInput.value = linkUrl;

                        if (linkUrl && linkUrl.startsWith("product/")) {
                            const uuid = linkUrl.split("product/")[1];
                            api.get<any>("/products/" + uuid).then((res) => {
                                if (res.data && res.data.name) {
                                    searchInput.value = res.data.name;
                                }
                            }).catch(() => {});
                        }
                        (
                            document.getElementById(
                                "b-order",
                            ) as HTMLInputElement
                        ).value = el.dataset.order!;
                        document
                            .getElementById("banner-form-error")!
                            .classList.add("hidden");
                        (
                            document.getElementById(
                                "banner-dialog",
                            ) as HTMLDialogElement
                        ).showModal();
                    });
                });
                document
                    .querySelectorAll(".delete-banner-btn")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            (
                                document.getElementById(
                                    "delete-banner-id",
                                ) as HTMLInputElement
                            ).value = (btn as HTMLElement).dataset.id!;
                            (
                                document.getElementById(
                                    "delete-banner-dialog",
                                ) as HTMLDialogElement
                            ).showModal();
                        });
                    });
            } catch (err: unknown) {
                grid.innerHTML = `<div class="col-span-full text-center py-10 text-red-400 text-sm">${err instanceof Error ? err.message : "Error"}</div>`;
            }
        }

        document.addEventListener("astro:page-load", () => {
            if (!window.location.pathname.startsWith("/header-images")) return;
            loadBanners();

            document
                .getElementById("btn-new-banner")
                ?.addEventListener("click", () => {
                    document.getElementById(
                        "banner-dialog-title",
                    )!.textContent = "Nuevo Banner";
                    document.getElementById("banner-submit-text")!.textContent =
                        "Crear Banner";
                    (
                        document.getElementById("banner-id") as HTMLInputElement
                    ).value = "";
                    (
                        document.getElementById(
                            "banner-form",
                        ) as HTMLFormElement
                    ).reset();
                    document
                        .getElementById("banner-form-error")!
                        .classList.add("hidden");
                    (
                        document.getElementById(
                            "banner-dialog",
                        ) as HTMLDialogElement
                    ).showModal();
                    (document.getElementById("b-link-search") as HTMLInputElement).value = "";
                });

            const closeBannerDialog = () =>
                (
                    document.getElementById(
                        "banner-dialog",
                    ) as HTMLDialogElement
                ).close();
            document
                .getElementById("close-banner-dialog")
                ?.addEventListener("click", closeBannerDialog);
            document
                .getElementById("cancel-banner-dialog")
                ?.addEventListener("click", closeBannerDialog);
            document
                .getElementById("banner-dialog")
                ?.addEventListener("click", (e) => {
                    if (e.target === e.currentTarget) closeBannerDialog();
                });

            document
                .getElementById("banner-form")
                ?.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const errBox =
                        document.getElementById("banner-form-error")!;
                    errBox.classList.add("hidden");
                    const id = (
                        document.getElementById("banner-id") as HTMLInputElement
                    ).value;
                    const name = (
                        document.getElementById("b-name") as HTMLInputElement
                    ).value.trim();
                    const image_url =
                        (
                            document.getElementById(
                                "b-image-url",
                            ) as HTMLInputElement
                        ).value.trim() ||
                        (
                            document.getElementById(
                                "b-image-url-manual",
                            ) as HTMLInputElement
                        ).value.trim();
                    const link_url = (
                        document.getElementById(
                            "b-link-url",
                        ) as HTMLInputElement
                    ).value.trim();
                    const display_order = parseInt(
                        (document.getElementById("b-order") as HTMLInputElement)
                            .value || "0",
                    );
                    const btn = document.getElementById(
                        "submit-banner",
                    ) as HTMLButtonElement;
                    btn.disabled = true;
                    try {
                        const body: Record<string, unknown> = {
                            name,
                            image_url,
                            display_order,
                            link_url: link_url || null,
                        };
                        if (id) {
                            await api.put(`/header-images/${id}`, body);
                            showToast("Banner actualizado", "success");
                        } else {
                            await api.post("/header-images", body);
                            showToast("Banner creado", "success");
                        }
                        closeBannerDialog();
                        loadBanners();
                    } catch (err: unknown) {
                        errBox.textContent =
                            err instanceof Error ? err.message : "Error";
                        errBox.classList.remove("hidden");
                    } finally {
                        btn.disabled = false;
                    }
                });

            // ── Image picker wiring ────────────────────────────────
            const bFileInput = document.getElementById(
                "b-image-file",
            ) as HTMLInputElement;
            const bUrlHidden = document.getElementById(
                "b-image-url",
            ) as HTMLInputElement;
            const bUrlManual = document.getElementById(
                "b-image-url-manual",
            ) as HTMLInputElement;
            const bPrevWrap = document.getElementById("b-image-preview-wrap")!;
            const bPrevImg = document.getElementById(
                "b-image-preview",
            ) as HTMLImageElement;
            const bClearBtn = document.getElementById("b-image-clear")!;
            const bFileLabelTx = document.getElementById(
                "b-image-file-label-text",
            )!;

            bFileInput?.addEventListener("change", async () => {
                const file = bFileInput.files?.[0];
                if (!file) return;

                // Show loading state
                bFileLabelTx.textContent = "Subiendo imagen…";
                bPrevWrap.classList.add("hidden");
                bUrlHidden.value = "";

                try {
                    const absoluteUrl = await uploadImage(file);
                    bUrlHidden.value = absoluteUrl;
                    bUrlManual.value = "";
                    bPrevImg.src = absoluteUrl;
                    bPrevWrap.classList.remove("hidden");
                    bFileLabelTx.textContent =
                        file.name.length > 22
                            ? file.name.slice(0, 20) + "…"
                            : file.name;
                    showToast("Imagen subida correctamente", "success");
                } catch (err: unknown) {
                    bFileInput.value = "";
                    bFileLabelTx.textContent = "Seleccionar archivo…";
                    showToast(
                        err instanceof Error
                            ? err.message
                            : "Error al subir imagen",
                        "error",
                    );
                }
            });

            bUrlManual?.addEventListener("input", () => {
                const val = bUrlManual.value.trim();
                bUrlHidden.value = val;
                if (val) {
                    bPrevImg.src = val;
                    bPrevWrap.classList.remove("hidden");
                    bFileLabelTx.textContent = "Seleccionar archivo…";
                    bFileInput.value = "";
                } else {
                    bPrevWrap.classList.add("hidden");
                    bUrlHidden.value = "";
                }
            });

            bClearBtn?.addEventListener("click", () => {
                bUrlHidden.value = "";
                bUrlManual.value = "";
                bFileInput.value = "";
                bPrevWrap.classList.add("hidden");
                bFileLabelTx.textContent = "Seleccionar archivo…";
            });

            // Reset picker when opening new banner dialog
            const origNewBanner = document.getElementById("btn-new-banner");
            origNewBanner?.addEventListener("click", () => {
                bUrlHidden.value = "";
                bUrlManual.value = "";
                bFileInput.value = "";
                bPrevWrap.classList.add("hidden");
                bFileLabelTx.textContent = "Seleccionar archivo…";
            });

            document
                .getElementById("cancel-delete-banner")
                ?.addEventListener("click", () =>
                    (
                        document.getElementById(
                            "delete-banner-dialog",
                        ) as HTMLDialogElement
                    ).close(),
                );
            document
                .getElementById("delete-banner-dialog")
                ?.addEventListener("click", (e) => {
                    if (e.target === e.currentTarget)
                        (
                            document.getElementById(
                                "delete-banner-dialog",
                            ) as HTMLDialogElement
                        ).close();
                });
            document
                .getElementById("confirm-delete-banner")
                ?.addEventListener("click", async () => {
                    const id = (
                        document.getElementById(
                            "delete-banner-id",
                        ) as HTMLInputElement
                    ).value;
                    try {
                        await api.delete(`/header-images/${id}`);
                        showToast("Banner eliminado", "success");
                        (
                            document.getElementById(
                                "delete-banner-dialog",
                            ) as HTMLDialogElement
                        ).close();
                        loadBanners();
                    } catch (err: unknown) {
                        showToast(
                            err instanceof Error ? err.message : "Error",
                            "error",
                        );
                    }
                });

            // Product Search Autocomplete logic
            const searchInput = document.getElementById("b-link-search") as HTMLInputElement;
            const hiddenLink = document.getElementById("b-link-url") as HTMLInputElement;
            const dropdown = document.getElementById("b-link-dropdown")!;
            const resultsUl = document.getElementById("b-link-results")!;
            let searchTimeout: ReturnType<typeof setTimeout>;

            searchInput.addEventListener("input", (e) => {
                const val = (e.target as HTMLInputElement).value.trim();
                if (val === "") {
                    hiddenLink.value = "";
                    dropdown.classList.add("hidden");
                    return;
                }
                
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(async () => {
                    try {
                        const res = await api.get<any>(`/products?search=${encodeURIComponent(val)}&limit=5`);
                        const products = res.data || [];
                        if (products.length === 0) {
                            resultsUl.innerHTML = '<li class="px-4 py-3 text-sm text-slate-500">No se encontraron productos</li>';
                        } else {
                            resultsUl.innerHTML = products.map((p: any) => `
                                <li class="px-4 py-2 border-b border-teal-900/10 hover:bg-teal-900/20 cursor-pointer flex items-center gap-3 transition-colors" data-id="${p.id}" data-name="${p.name}">
                                    <img src="${p.image_url}" class="w-8 h-8 rounded object-cover bg-surface-900 shrink-0" />
                                    <div class="truncate">
                                        <p class="text-sm text-white truncate">${p.name}</p>
                                    </div>
                                </li>
                            `).join("");

                            resultsUl.querySelectorAll("li[data-id]").forEach(li => {
                                li.addEventListener("click", () => {
                                    const id = (li as HTMLElement).dataset.id!;
                                    const name = (li as HTMLElement).dataset.name!;
                                    searchInput.value = name;
                                    hiddenLink.value = `product/${id}`;
                                    dropdown.classList.add("hidden");
                                });
                            });
                        }
                        dropdown.classList.remove("hidden");
                    } catch (err) {
                        console.error(err);
                    }
                }, 300);
            });

            document.addEventListener("click", (e) => {
                if (!searchInput.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
                    dropdown.classList.add("hidden");
                }
            });
        });
    </script>
</Layout>
