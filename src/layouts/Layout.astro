---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
    title?: string;
    activeNav?: string;
}

const { title = "Ecommerce CMS", activeNav = "" } = Astro.props;

const navItems = [
    {
        href: "/",
        label: "Dashboard",
        key: "dashboard",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
    },
    {
        href: "/products",
        label: "Productos",
        key: "products",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
    },
    {
        href: "/categories",
        label: "Listas",
        key: "categories",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
    },
    {
        href: "/orders",
        label: "Pedidos",
        key: "orders",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>`,
    },
    {
        href: "/header-images",
        label: "Banners",
        key: "header-images",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 14 3-3 3 3"/><circle cx="9" cy="9" r="1" fill="currentColor"/></svg>`,
    },
    {
        href: "/payment-methods",
        label: "Métodos de Pago",
        key: "payment-methods",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
    },
    {
        href: "/customers",
        label: "Clientes",
        key: "customers",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    },
    {
        href: "/accounts",
        label: "Cuentas",
        key: "accounts",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/><path d="M15 11l3 3-3 3"/></svg>`,
    },
];
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <title>{title} - CMS</title>
        <ClientRouter />
    </head>

    <body class="flex min-h-dvh bg-surface-950">
        <!-- ─── Backdrop for Mobile Sidebar ──────────────────────── -->
        <div
            id="sidebar-backdrop"
            class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity opacity-0 backdrop-blur-sm"
        ></div>

        <!-- ─── Sidebar ──────────────────────────────────────────── -->
        <aside
            id="sidebar"
            class="fixed inset-y-0 left-0 z-40 flex flex-col w-64 shrink-0 glass-card border-r border-teal-900/20 h-dvh overflow-y-auto transition-all duration-300 -translate-x-full md:sticky md:top-0 md:left-auto md:translate-x-0 md:z-30"
        >
            <!-- Logo -->
            <div
                class="flex items-center gap-3 px-5 py-5 border-b border-teal-900/20"
            >
                <div
                    class="w-9 h-9 rounded-lg bg-gradient-brand flex items-center justify-center glow-teal-sm shrink-0"
                >
                    <svg
                        width="20"
                        height="20"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="white"
                        stroke-width="2.5"
                    >
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-white leading-none">
                        Ecommerce
                    </p>
                    <p class="text-xs text-slate-500 mt-0.5">
                        Panel de Control
                    </p>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-0.5">
                <p
                    class="text-xs font-semibold text-slate-600 uppercase tracking-widest px-2 mb-3"
                >
                    Módulos
                </p>
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class={`nav-item ${activeNav === item.key ? "active" : ""}`}
                        >
                            <span set:html={item.icon} />
                            {item.label}
                            {item.key === "orders" && (
                                <span
                                    id="sidebar-pending-badge"
                                    class="ml-auto text-xs bg-yellow-400/20 text-yellow-400 border border-yellow-400/30 rounded-full px-2 py-0.5 hidden"
                                />
                            )}
                        </a>
                    ))
                }
            </nav>

            <!-- User footer -->
            <div class="px-3 py-4 border-t border-teal-900/20">
                <div class="flex items-center gap-3 px-2 mb-3">
                    <div
                        class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center text-sm font-bold text-white shrink-0"
                    >
                        <span id="user-avatar-initial">A</span>
                    </div>
                    <div class="min-w-0">
                        <p
                            id="user-email-display"
                            class="text-xs font-medium text-slate-300 truncate"
                        >
                            admin@ecommerce.mx
                        </p>
                        <p class="text-xs text-slate-500">Administrador</p>
                    </div>
                </div>
                <button
                    id="logout-btn"
                    class="btn-secondary w-full text-xs py-2"
                >
                    <svg
                        width="14"
                        height="14"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                        ></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Cerrar sesión
                </button>
            </div>
        </aside>

        <!-- ─── Main area ─────────────────────────────────────────── -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- Header -->
            <header
                class="sticky top-0 z-20 glass-card border-b border-teal-900/20 px-4 md:px-6 py-3.5 flex items-center justify-between gap-4"
            >
                <div class="flex items-center gap-3 min-w-0">
                    <button
                        id="menu-btn"
                        class="p-2 -ml-2 text-slate-300 hover:text-white focus:outline-none shrink-0"
                        aria-label="Alternar menú"
                    >
                        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                    <h1 class="text-base font-semibold text-white truncate">
                        {title}
                    </h1>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                    <!-- Clock -->
                    <div
                        id="clock"
                        class="text-xs text-slate-500 hidden md:block"
                    >
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 p-4 md:p-6 animate-fade-in-up max-w-full overflow-x-hidden">
                <slot />
            </main>
        </div>

        <!-- ─── Toast container ───────────────────────────────────── -->
        <div class="toast-container"></div>

        <!-- ─── JWT Expired modal ────────────────────────────────── -->
        <dialog id="session-expired-dialog">
            <div
                class="modal-box max-w-sm"
                style="border-color: rgba(239,68,68,0.25); box-shadow: 0 25px 50px rgba(0,0,0,0.6), 0 0 60px rgba(239,68,68,0.08);"
            >
                <!-- Animated warning icon -->
                <div class="flex flex-col items-center text-center mb-6">
                    <div
                        id="session-icon-ring"
                        style="
                        width: 72px; height: 72px;
                        border-radius: 50%;
                        background: rgba(239,68,68,0.1);
                        border: 2px solid rgba(239,68,68,0.3);
                        display: flex; align-items: center; justify-content: center;
                        margin-bottom: 1.25rem;
                        position: relative;
                        animation: sessionPulse 2s ease-in-out infinite;
                    "
                    >
                        <!-- outer pulse ring -->
                        <span
                            style="
                            position: absolute; inset: -8px;
                            border-radius: 50%;
                            border: 2px solid rgba(239,68,68,0.2);
                            animation: sessionRipple 2s ease-in-out infinite;
                        "
                        ></span>
                        <svg
                            width="32"
                            height="32"
                            fill="none"
                            stroke="#f87171"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"
                            ></path>
                        </svg>
                    </div>

                    <h3 class="text-lg font-bold text-white mb-1.5">
                        Sesión Expirada
                    </h3>
                    <p class="text-sm text-slate-400 leading-relaxed">
                        Tu sesión ha caducado por inactividad.<br />
                        Por seguridad, necesitas iniciar sesión nuevamente.
                    </p>
                </div>

                <!-- Countdown progress bar -->
                <div style="margin-bottom: 1.5rem;">
                    <div
                        style="
                        display: flex; justify-content: space-between;
                        font-size: 0.75rem; color: #64748b; margin-bottom: 0.5rem;
                    "
                    >
                        <span>Redirigiendo automáticamente…</span>
                        <span
                            id="session-countdown"
                            style="color: #f87171; font-weight: 600;">5s</span
                        >
                    </div>
                    <div
                        style="
                        height: 4px; background: rgba(30,41,59,0.8);
                        border-radius: 999px; overflow: hidden;
                    "
                    >
                        <div
                            id="session-progress-bar"
                            style="
                            height: 100%;
                            width: 100%;
                            background: linear-gradient(90deg, #dc2626, #f87171);
                            border-radius: 999px;
                            transition: width 1s linear;
                        "
                        >
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex gap-3">
                    <button
                        id="session-login-now"
                        class="btn-primary flex-1"
                        style="background: #dc2626;"
                    >
                        <svg
                            width="16"
                            height="16"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"
                            ></path>
                        </svg>
                        Iniciar Sesión Ahora
                    </button>
                </div>
            </div>
        </dialog>

        <script>
            import {
                getAccessToken,
                authLogout,
                clearTokens,
            } from "../utils/api.ts";

            // ── Route guard ───────────────────────────────────────────
            document.addEventListener("astro:page-load", () => {
                const isLoginPage = window.location.pathname === "/login";
                const token = getAccessToken();

                if (!token && !isLoginPage) {
                    window.location.href = "/login";
                    return;
                }
                if (token && isLoginPage) {
                    window.location.href = "/";
                    return;
                }

                // ── Mobile & Desktop Menu Toggle ──────────────────────────
                const sidebar = document.getElementById("sidebar");
                const menuBtn = document.getElementById("menu-btn");
                const backdrop = document.getElementById("sidebar-backdrop");

                // Restore desktop state from localStorage
                if (window.innerWidth >= 768) {
                    const isDesktopClosed = localStorage.getItem("sidebar-desktop-closed") === "true";
                    if (isDesktopClosed) {
                        sidebar?.classList.add("sidebar-desktop-closed");
                    }
                }

                const toggleMenu = (forceCloseMobile = false) => {
                    const isMobile = window.innerWidth < 768;
                    
                    if (isMobile) {
                        const isClosed = sidebar?.classList.contains("-translate-x-full");
                        if (forceCloseMobile && isClosed) return;
                        
                        if (isClosed && !forceCloseMobile) {
                            // Open mobile menu
                            sidebar?.classList.remove("-translate-x-full");
                            backdrop?.classList.remove("hidden");
                            setTimeout(() => backdrop?.classList.remove("opacity-0"), 10);
                            document.body.style.overflow = "hidden";
                        } else {
                            // Close mobile menu
                            sidebar?.classList.add("-translate-x-full");
                            backdrop?.classList.add("opacity-0");
                            setTimeout(() => backdrop?.classList.add("hidden"), 300);
                            document.body.style.overflow = "";
                        }
                    } else {
                        // Desktop menu logic
                        if (forceCloseMobile) return; // Backdrop click doesn't apply to desktop
                        
                        const isClosed = sidebar?.classList.contains("sidebar-desktop-closed");
                        if (isClosed) {
                            sidebar?.classList.remove("sidebar-desktop-closed");
                            localStorage.setItem("sidebar-desktop-closed", "false");
                        } else {
                            sidebar?.classList.add("sidebar-desktop-closed");
                            localStorage.setItem("sidebar-desktop-closed", "true");
                        }
                    }
                };

                menuBtn?.addEventListener("click", () => toggleMenu(false));

                backdrop?.addEventListener("click", () => {
                    if (window.innerWidth < 768) toggleMenu(true);
                });

                // Logout button
                const logoutBtn = document.getElementById("logout-btn");
                if (logoutBtn) {
                    logoutBtn.addEventListener("click", () => authLogout());
                }

                // Clock
                const clockEl = document.getElementById("clock");
                if (clockEl) {
                    const tick = () => {
                        clockEl.textContent = new Date().toLocaleTimeString(
                            "es-MX",
                            {
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit",
                            },
                        );
                    };
                    tick();
                    const timer = setInterval(tick, 1000);
                    document.addEventListener(
                        "astro:before-preparation",
                        () => clearInterval(timer),
                        { once: true },
                    );
                }

                // User email display
                const emailDisplay =
                    document.getElementById("user-email-display");
                const avatarInitial = document.getElementById(
                    "user-avatar-initial",
                );
                const storedEmail = localStorage.getItem("vz_user_email");
                if (emailDisplay && storedEmail)
                    emailDisplay.textContent = storedEmail;
                if (avatarInitial && storedEmail)
                    avatarInitial.textContent = storedEmail
                        .charAt(0)
                        .toUpperCase();

                // ── JWT Session expired handler ────────────────────────
                const sessionDialog = document.getElementById(
                    "session-expired-dialog",
                ) as HTMLDialogElement | null;

                const showSessionExpired = () => {
                    if (!sessionDialog || sessionDialog.open) return;
                    sessionDialog.showModal();

                    let secs = 5;
                    const countdownEl =
                        document.getElementById("session-countdown");
                    const progressBar = document.getElementById(
                        "session-progress-bar",
                    );

                    // Animate bar to 0% over 5 seconds
                    requestAnimationFrame(() => {
                        if (progressBar) progressBar.style.width = "0%";
                    });

                    const interval = setInterval(() => {
                        secs--;
                        if (countdownEl) countdownEl.textContent = `${secs}s`;
                        if (secs <= 0) {
                            clearInterval(interval);
                            window.location.href = "/login";
                        }
                    }, 1000);

                    const loginNowBtn =
                        document.getElementById("session-login-now");
                    loginNowBtn?.addEventListener(
                        "click",
                        () => {
                            clearInterval(interval);
                            window.location.href = "/login";
                        },
                        { once: true },
                    );
                };

                window.addEventListener("session:expired", showSessionExpired);
            });
        </script>
    </body>
</html>
