---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
    title?: string;
    activeNav?: string;
}

const { title = "Ecommerce CMS", activeNav = "" } = Astro.props;

const navItems = [
    {
        href: "/",
        label: "Dashboard",
        key: "dashboard",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
    },
    {
        href: "/products",
        label: "Productos",
        key: "products",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
    },
    {
        href: "/categories",
        label: "Listas",
        key: "categories",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
    },
    {
        href: "/orders",
        label: "Pedidos",
        key: "orders",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>`,
    },
    {
        href: "/header-images",
        label: "Banners",
        key: "header-images",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 14 3-3 3 3"/><circle cx="9" cy="9" r="1" fill="currentColor"/></svg>`,
    },
    {
        href: "/payment-methods",
        label: "Métodos de Pago",
        key: "payment-methods",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
    },
    {
        href: "/customers",
        label: "Clientes",
        key: "customers",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    },
    {
        href: "/accounts",
        label: "Cuentas",
        key: "accounts",
        icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/><path d="M15 11l3 3-3 3"/></svg>`,
    },
];
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <title>{title} — Ecommerce CMS</title>
        <ClientRouter />
    </head>

    <body class="flex min-h-dvh bg-surface-950">
        <!-- ─── Sidebar ──────────────────────────────────────────── -->
        <aside
            id="sidebar"
            class="flex flex-col w-64 shrink-0 glass-card border-r border-teal-900/20 min-h-dvh sticky top-0 h-dvh overflow-y-auto z-30 transition-transform duration-300"
        >
            <!-- Logo -->
            <div
                class="flex items-center gap-3 px-5 py-5 border-b border-teal-900/20"
            >
                <div
                    class="w-9 h-9 rounded-lg bg-gradient-brand flex items-center justify-center glow-teal-sm shrink-0"
                >
                    <svg
                        width="20"
                        height="20"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="white"
                        stroke-width="2.5"
                    >
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-white leading-none">
                        Ecommerce
                    </p>
                    <p class="text-xs text-slate-500 mt-0.5">
                        Panel de Control
                    </p>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-0.5">
                <p
                    class="text-xs font-semibold text-slate-600 uppercase tracking-widest px-2 mb-3"
                >
                    Módulos
                </p>
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class={`nav-item ${activeNav === item.key ? "active" : ""}`}
                        >
                            <span set:html={item.icon} />
                            {item.label}
                            {item.key === "orders" && (
                                <span
                                    id="sidebar-pending-badge"
                                    class="ml-auto text-xs bg-yellow-400/20 text-yellow-400 border border-yellow-400/30 rounded-full px-2 py-0.5 hidden"
                                />
                            )}
                        </a>
                    ))
                }
            </nav>

            <!-- User footer -->
            <div class="px-3 py-4 border-t border-teal-900/20">
                <div class="flex items-center gap-3 px-2 mb-3">
                    <div
                        class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center text-sm font-bold text-white shrink-0"
                    >
                        <span id="user-avatar-initial">A</span>
                    </div>
                    <div class="min-w-0">
                        <p
                            id="user-email-display"
                            class="text-xs font-medium text-slate-300 truncate"
                        >
                            admin@ecommerce.mx
                        </p>
                        <p class="text-xs text-slate-500">Administrador</p>
                    </div>
                </div>
                <button
                    id="logout-btn"
                    class="btn-secondary w-full text-xs py-2"
                >
                    <svg
                        width="14"
                        height="14"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                        ></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Cerrar sesión
                </button>
            </div>
        </aside>

        <!-- ─── Main area ─────────────────────────────────────────── -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- Header -->
            <header
                class="sticky top-0 z-20 glass-card border-b border-teal-900/20 px-6 py-3.5 flex items-center justify-between gap-4"
            >
                <div class="flex items-center gap-3 min-w-0">
                    <h1 class="text-base font-semibold text-white truncate">
                        {title}
                    </h1>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                    <!-- API URL indicator -->
                    <div
                        id="api-status"
                        class="flex items-center gap-2 text-xs text-slate-500 bg-slate-900/60 border border-slate-800 rounded-lg px-3 py-1.5 cursor-pointer hover:border-teal-700/40 transition-colors"
                        title="URL de la API"
                    >
                        <span
                            class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"
                        ></span>
                        <span id="api-url-label">localhost:3000</span>
                    </div>
                    <!-- Clock -->
                    <div
                        id="clock"
                        class="text-xs text-slate-500 hidden md:block"
                    >
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 p-6 animate-fade-in-up">
                <slot />
            </main>
        </div>

        <!-- ─── Toast container ───────────────────────────────────── -->
        <div class="toast-container"></div>

        <!-- ─── API URL modal ────────────────────────────────────── -->
        <dialog id="api-url-dialog">
            <div class="modal-box max-w-sm">
                <div class="flex items-center justify-between mb-5">
                    <h3 class="text-base font-semibold text-white">
                        Configurar URL de la API
                    </h3>
                    <button id="close-api-dialog" class="btn-icon btn-icon-red">
                        <svg
                            width="14"
                            height="14"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            ><path d="M18 6 6 18M6 6l12 12"></path></svg
                        >
                    </button>
                </div>
                <label class="form-label">URL Base del Backend</label>
                <input
                    id="api-url-input"
                    type="url"
                    class="form-input"
                    placeholder="http://localhost:3000"
                />
                <p class="text-xs text-slate-500 mt-2 mb-5">
                    Sin barra al final. Ej: <code class="text-teal-400"
                        >http://localhost:3000</code
                    >
                </p>
                <div class="flex gap-3 justify-end">
                    <button id="cancel-api-dialog" class="btn-secondary"
                        >Cancelar</button
                    >
                    <button id="save-api-url" class="btn-primary"
                        >Guardar</button
                    >
                </div>
            </div>
        </dialog>

        <script>
            import {
                getApiUrl,
                setApiUrl,
                getAccessToken,
                authLogout,
                clearTokens,
            } from "../utils/api.ts";

            // ── Route guard ───────────────────────────────────────────
            document.addEventListener("astro:page-load", () => {
                const isLoginPage = window.location.pathname === "/login";
                const token = getAccessToken();

                if (!token && !isLoginPage) {
                    window.location.href = "/login";
                    return;
                }
                if (token && isLoginPage) {
                    window.location.href = "/";
                    return;
                }

                // Update API URL label
                const apiUrlLabel = document.getElementById("api-url-label");
                if (apiUrlLabel) {
                    const url = getApiUrl();
                    try {
                        const u = new URL(url);
                        apiUrlLabel.textContent = u.host;
                    } catch {
                        apiUrlLabel.textContent = url;
                    }
                }

                // Logout button
                const logoutBtn = document.getElementById("logout-btn");
                if (logoutBtn) {
                    logoutBtn.addEventListener("click", () => authLogout());
                }

                // API URL dialog
                const apiStatus = document.getElementById("api-status");
                const apiDialog = document.getElementById(
                    "api-url-dialog",
                ) as HTMLDialogElement | null;
                const apiInput = document.getElementById(
                    "api-url-input",
                ) as HTMLInputElement | null;
                const saveBtn = document.getElementById("save-api-url");
                const cancelBtn = document.getElementById("cancel-api-dialog");
                const closeBtn = document.getElementById("close-api-dialog");

                if (apiStatus && apiDialog && apiInput) {
                    apiStatus.addEventListener("click", () => {
                        apiInput.value = getApiUrl();
                        apiDialog.showModal();
                    });
                    const closeDialog = () => apiDialog.close();
                    cancelBtn?.addEventListener("click", closeDialog);
                    closeBtn?.addEventListener("click", closeDialog);
                    saveBtn?.addEventListener("click", () => {
                        const val = apiInput.value.trim();
                        if (val) {
                            setApiUrl(val);
                            const label =
                                document.getElementById("api-url-label");
                            if (label) {
                                try {
                                    label.textContent = new URL(val).host;
                                } catch {
                                    label.textContent = val;
                                }
                            }
                        }
                        closeDialog();
                    });
                    apiDialog.addEventListener("click", (e) => {
                        if (e.target === apiDialog) closeDialog();
                    });
                }

                // Clock
                const clockEl = document.getElementById("clock");
                if (clockEl) {
                    const tick = () => {
                        clockEl.textContent = new Date().toLocaleTimeString(
                            "es-MX",
                            {
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit",
                            },
                        );
                    };
                    tick();
                    const timer = setInterval(tick, 1000);
                    document.addEventListener(
                        "astro:before-preparation",
                        () => clearInterval(timer),
                        { once: true },
                    );
                }

                // User email display
                const emailDisplay =
                    document.getElementById("user-email-display");
                const avatarInitial = document.getElementById(
                    "user-avatar-initial",
                );
                const storedEmail = localStorage.getItem("vz_user_email");
                if (emailDisplay && storedEmail)
                    emailDisplay.textContent = storedEmail;
                if (avatarInitial && storedEmail)
                    avatarInitial.textContent = storedEmail
                        .charAt(0)
                        .toUpperCase();
            });
        </script>
    </body>
</html>
